# ─────────────────────────────────────────────────────────────────────────────
# Poiro — Root Environment Variables
#
# Copy to .env and fill in real values before starting the API or worker.
# Also copy apps/api/.env.example → apps/api/.env
#        apps/web/.env.local.example → apps/web/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (e.g. https://abcxyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Publishable key — new-style sb_publishable_... (replaces legacy anon key)
# Safe to use in the backend Supabase client for Auth operations.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — new-style sb_secret_... (replaces legacy service_role key)
# NEVER expose publicly.
SUPABASE_SECRET_KEY=sb_secret_...

# Direct Postgres URL for SQLAlchemy (asyncpg)
# Format: postgresql+asyncpg://postgres.[project-ref]:<password>@<host>:5432/postgres
SUPABASE_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=mock
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── API ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
DEBUG=false

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000
